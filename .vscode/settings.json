{
  "prettier.singleAttributePerLine": false,
  "remote.portsAttributes": {
    "443": {
      "protocol": "https"
    },
    "8443": {
      "protocol": "https"
    }
  },
  "javascript.preferences.jsxAttributeCompletionStyle": "auto",
  "html.format.wrapAttributes": "auto",
